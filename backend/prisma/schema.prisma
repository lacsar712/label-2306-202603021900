generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  username              String                 @unique
  password              String
  role                  String                 @default("ADMIN")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  assignedTickets       Ticket[]               @relation("AssignedTickets")
  ticketReplies         TicketReply[]
  uploadedAttachments   TicketAttachment[]
  collaboratedTickets   TicketCollaborator[]   @relation("CollaboratedTickets")
  assignmentRules       TicketAssignmentRule[]
  managedChannels       Channel[]              @relation("ChannelManagers")

  @@map("users")
}

model Member {
  id              Int         @id @default(autoincrement())
  name            String
  phone           String      @unique
  email           String?
  level           MemberLevel @default(NORMAL)
  status          MemberStatus @default(ACTIVE)
  points          Int         @default(0)
  joinDate        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  sourceChannelId Int?
  sourceChannel   Channel?    @relation("MemberSourceChannel", fields: [sourceChannelId], references: [id])
  firstTouchAt    DateTime?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?

  tickets   Ticket[]
  campaignParticipations CampaignParticipation[]
  signins   MemberSignin[]
  exchanges MemberExchange[]
  pointsLogs MemberPointsLog[]

  @@index([sourceChannelId])
  @@map("members")
}

enum MemberLevel {
  NORMAL
  SILVER
  GOLD
  PLATINUM
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketCategory {
  CONSULTATION
  COMPLAINT
  SUGGESTION
  AFTERSALE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  PENDING_ASSIGN
  PENDING_PROCESS
  PROCESSING
  PENDING_REVIEW
  CLOSED
  REJECTED
}

model Ticket {
  id              Int              @id @default(autoincrement())
  memberId        Int
  member          Member           @relation(fields: [memberId], references: [id])
  title           String
  content         String
  category        TicketCategory
  priority        TicketPriority   @default(MEDIUM)
  status          TicketStatus     @default(PENDING_ASSIGN)
  assigneeId      Int?
  assignee        User?            @relation("AssignedTickets", fields: [assigneeId], references: [id])
  slaDeadline     DateTime?
  satisfaction    Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  replies         TicketReply[]
  attachments     TicketAttachment[]
  collaborators   TicketCollaborator[]

  @@map("tickets")
}

model TicketReply {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId          Int?
  user            User?            @relation(fields: [userId], references: [id])
  content         String
  actionType      String?
  actionDetail    String?
  createdAt       DateTime         @default(now())

  @@map("ticket_replies")
}

model TicketAttachment {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int?
  uploaderId      Int?
  uploader        User?            @relation(fields: [uploaderId], references: [id])
  createdAt       DateTime         @default(now())

  @@map("ticket_attachments")
}

model TicketCollaborator {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId          Int
  user            User             @relation("CollaboratedTickets", fields: [userId], references: [id])
  createdAt       DateTime         @default(now())

  @@unique([ticketId, userId])
  @@map("ticket_collaborators")
}

model TicketAssignmentRule {
  id              Int              @id @default(autoincrement())
  category        TicketCategory   @unique
  defaultAssigneeId Int
  defaultAssignee User             @relation(fields: [defaultAssigneeId], references: [id])
  slaHours        Int              @default(24)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("ticket_assignment_rules")
}

enum CampaignType {
  DOUBLE_POINTS
  SPEND_GIFT_POINTS
  LEVEL_BONUS
  SIGNIN_DOUBLE
  EXCHANGE_DISCOUNT
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  ENDED
  VOID
}

model Campaign {
  id                Int              @id @default(autoincrement())
  name              String
  type              CampaignType
  ruleParams        Json
  startTime         DateTime
  endTime           DateTime
  applicableLevels  Json?
  applicableTags    Json?
  applicableChannels Json?
  participationLimit Int             @default(0)
  mutualExclusionGroup String?
  priority          Int              @default(0)
  status            CampaignStatus   @default(DRAFT)
  enabled           Boolean          @default(true)
  createdBy         Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  participations    CampaignParticipation[]
  pointsLogs        MemberPointsLog[]

  @@index([status, startTime, endTime])
  @@map("campaigns")
}

model CampaignParticipation {
  id           Int        @id @default(autoincrement())
  campaignId   Int
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memberId     Int
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  actionType   String
  originalValue Int
  bonusValue    Int
  finalValue    Int
  ruleHitDetail Json?
  createdAt    DateTime   @default(now())

  @@index([campaignId, createdAt])
  @@index([memberId, createdAt])
  @@map("campaign_participations")
}

model MemberSignin {
  id         Int      @id @default(autoincrement())
  memberId   Int
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  signinDate DateTime @db.Date
  points     Int      @default(10)
  createdAt  DateTime @default(now())

  @@unique([memberId, signinDate])
  @@index([memberId, signinDate])
  @@map("member_signins")
}

model MemberExchange {
  id            Int      @id @default(autoincrement())
  memberId      Int
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  itemName      String
  originalPoints Int
  finalPoints   Int
  createdAt     DateTime @default(now())

  @@index([memberId, createdAt])
  @@map("member_exchanges")
}

model MemberPointsLog {
  id            Int      @id @default(autoincrement())
  memberId      Int
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  changePoints  Int
  balanceAfter  Int
  reason        String
  campaignId    Int?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([memberId, createdAt])
  @@map("member_points_logs")
}

model Channel {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  parentId    Int?
  parent      Channel?  @relation("ChannelTree", fields: [parentId], references: [id])
  children    Channel[] @relation("ChannelTree")
  level       Int       @default(1)
  sortOrder   Int       @default(0)
  managerId   Int?
  manager     User?     @relation("ChannelManagers", fields: [managerId], references: [id])
  isActive    Boolean   @default(true)
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     Member[]  @relation("MemberSourceChannel")

  @@index([parentId])
  @@index([managerId])
  @@map("channels")
}
