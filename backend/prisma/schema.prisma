generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  username              String                 @unique
  password              String
  role                  String                 @default("ADMIN")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  assignedTickets       Ticket[]               @relation("AssignedTickets")
  ticketReplies         TicketReply[]
  uploadedAttachments   TicketAttachment[]
  collaboratedTickets   TicketCollaborator[]   @relation("CollaboratedTickets")
  assignmentRules       TicketAssignmentRule[]
  managedChannels       Channel[]              @relation("ChannelManagers")
  dashboardConfig       DashboardConfig?
  blacklistsAdded       Blacklist[]
  blacklistsReleased    Blacklist[]            @relation("BlacklistReleasedBy")
  blacklistsApproved    Blacklist[]            @relation("BlacklistApprovedBy")
  blacklistAuditLogs    BlacklistAuditLog[]

  @@map("users")
}

model Member {
  id              Int         @id @default(autoincrement())
  name            String
  phone           String      @unique
  email           String?
  level           MemberLevel @default(NORMAL)
  status          MemberStatus @default(ACTIVE)
  points          Int         @default(0)
  frozenPoints    Int         @default(0)
  joinDate        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  sourceChannelId Int?
  sourceChannel   Channel?    @relation("MemberSourceChannel", fields: [sourceChannelId], references: [id])
  firstTouchAt    DateTime?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrerId      Int?
  referrer        Member?     @relation("ReferralTree", fields: [referrerId], references: [id])
  referrals       Member[]    @relation("ReferralTree")
  totalConsumption Float      @default(0)
  firstOrderAt    DateTime?

  tickets   Ticket[]
  campaignParticipations CampaignParticipation[]
  signins   MemberSignin[]
  exchanges MemberExchange[]
  pointsLogs MemberPointsLog[]
  pointsLedgers PointsLedger[]
  reminderLogs PointsReminderLog[]
  referralCodes ReferralCode[]
  referralRewardsAsReferrer ReferralReward[] @relation("ReferrerRewards")
  referralRewardsAsReferee ReferralReward[] @relation("RefereeRewards")
  blacklists Blacklist[]
  blacklistAuditLogs BlacklistAuditLog[]

  @@index([sourceChannelId])
  @@index([referrerId])
  @@map("members")
}

enum MemberLevel {
  NORMAL
  SILVER
  GOLD
  PLATINUM
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketCategory {
  CONSULTATION
  COMPLAINT
  SUGGESTION
  AFTERSALE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  PENDING_ASSIGN
  PENDING_PROCESS
  PROCESSING
  PENDING_REVIEW
  CLOSED
  REJECTED
}

model Ticket {
  id              Int              @id @default(autoincrement())
  memberId        Int
  member          Member           @relation(fields: [memberId], references: [id])
  title           String
  content         String
  category        TicketCategory
  priority        TicketPriority   @default(MEDIUM)
  status          TicketStatus     @default(PENDING_ASSIGN)
  assigneeId      Int?
  assignee        User?            @relation("AssignedTickets", fields: [assigneeId], references: [id])
  slaDeadline     DateTime?
  satisfaction    Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  replies         TicketReply[]
  attachments     TicketAttachment[]
  collaborators   TicketCollaborator[]

  @@map("tickets")
}

model TicketReply {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId          Int?
  user            User?            @relation(fields: [userId], references: [id])
  content         String
  actionType      String?
  actionDetail    String?
  createdAt       DateTime         @default(now())

  @@map("ticket_replies")
}

model TicketAttachment {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int?
  uploaderId      Int?
  uploader        User?            @relation(fields: [uploaderId], references: [id])
  createdAt       DateTime         @default(now())

  @@map("ticket_attachments")
}

model TicketCollaborator {
  id              Int              @id @default(autoincrement())
  ticketId        Int
  ticket          Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId          Int
  user            User             @relation("CollaboratedTickets", fields: [userId], references: [id])
  createdAt       DateTime         @default(now())

  @@unique([ticketId, userId])
  @@map("ticket_collaborators")
}

model TicketAssignmentRule {
  id              Int              @id @default(autoincrement())
  category        TicketCategory   @unique
  defaultAssigneeId Int
  defaultAssignee User             @relation(fields: [defaultAssigneeId], references: [id])
  slaHours        Int              @default(24)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("ticket_assignment_rules")
}

enum CampaignType {
  DOUBLE_POINTS
  SPEND_GIFT_POINTS
  LEVEL_BONUS
  SIGNIN_DOUBLE
  EXCHANGE_DISCOUNT
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  ENDED
  VOID
}

model Campaign {
  id                Int              @id @default(autoincrement())
  name              String
  type              CampaignType
  ruleParams        Json
  startTime         DateTime
  endTime           DateTime
  applicableLevels  Json?
  applicableTags    Json?
  applicableChannels Json?
  participationLimit Int             @default(0)
  mutualExclusionGroup String?
  priority          Int              @default(0)
  status            CampaignStatus   @default(DRAFT)
  enabled           Boolean          @default(true)
  createdBy         Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  participations    CampaignParticipation[]
  pointsLogs        MemberPointsLog[]

  @@index([status, startTime, endTime])
  @@map("campaigns")
}

model CampaignParticipation {
  id           Int        @id @default(autoincrement())
  campaignId   Int
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memberId     Int
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  actionType   String
  originalValue Int
  bonusValue    Int
  finalValue    Int
  ruleHitDetail Json?
  createdAt    DateTime   @default(now())

  @@index([campaignId, createdAt])
  @@index([memberId, createdAt])
  @@map("campaign_participations")
}

model MemberSignin {
  id               Int      @id @default(autoincrement())
  memberId         Int
  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  signinDate       DateTime @db.Date
  points           Int      @default(10)
  consecutiveDays  Int      @default(1)
  isMakeup         Boolean  @default(false)
  makeupCostPoints Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([memberId, signinDate])
  @@index([memberId, signinDate])
  @@map("member_signins")
}

model SigninConfig {
  id                      Int   @id @default(autoincrement())
  basePoints              Int   @default(10)
  consecutiveBonusRules   Json  @default("[]")
  monthlyMakeupLimit      Int   @default(3)
  makeupCostPoints        Int   @default(50)
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())

  @@map("signin_configs")
}

model MemberExchange {
  id            Int      @id @default(autoincrement())
  memberId      Int
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  itemName      String
  originalPoints Int
  finalPoints   Int
  createdAt     DateTime @default(now())

  @@index([memberId, createdAt])
  @@map("member_exchanges")
}

model MemberPointsLog {
  id            Int      @id @default(autoincrement())
  memberId      Int
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  changePoints  Int
  balanceAfter  Int
  reason        String
  campaignId    Int?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([memberId, createdAt])
  @@map("member_points_logs")
}

model Channel {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  parentId    Int?
  parent      Channel?  @relation("ChannelTree", fields: [parentId], references: [id])
  children    Channel[] @relation("ChannelTree")
  level       Int       @default(1)
  sortOrder   Int       @default(0)
  managerId   Int?
  manager     User?     @relation("ChannelManagers", fields: [managerId], references: [id])
  isActive    Boolean   @default(true)
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     Member[]  @relation("MemberSourceChannel")

  @@index([parentId])
  @@index([managerId])
  @@map("channels")
}

enum PointsSourceType {
  CONSUMPTION
  ACTIVITY
  SIGNIN
  ADJUST
  EXCHANGE_REFUND
  OTHER
}

enum ExpiryHandleType {
  CLEAR_ALL
  FIFO_DEDUCT
  TRANSFER_FROZEN
}

enum PointsLedgerStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  FROZEN
  EXEMPTED
}

model PointsExpiryRule {
  id               Int                @id @default(autoincrement())
  name             String
  sourceType       PointsSourceType   @unique
  validDays        Int
  isEnabled        Boolean            @default(true)
  reminderDays     Json               @default("[]")
  handleType       ExpiryHandleType   @default(CLEAR_ALL)
  createdBy        Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  ledgers          PointsLedger[]

  @@map("points_expiry_rules")
}

model PointsLedger {
  id               Int                @id @default(autoincrement())
  memberId         Int
  member           Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ruleId           Int?
  rule             PointsExpiryRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  sourceType       PointsSourceType
  originalPoints   Int
  remainingPoints  Int
  earnedAt         DateTime           @default(now())
  expireAt         DateTime
  status           PointsLedgerStatus @default(ACTIVE)
  sourceLogId      Int?
  campaignId       Int?
  exempted         Boolean            @default(false)
  extendedDays     Int                @default(0)
  remark           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  reminderLogs     PointsReminderLog[]

  @@index([memberId, status, expireAt])
  @@index([expireAt, status])
  @@map("points_ledger")
}

model PointsExpiryExecution {
  id               Int                @id @default(autoincrement())
  executionDate    DateTime           @db.Date
  totalExpiredPoints Int              @default(0)
  affectedMembers  Int                @default(0)
  totalFrozenPoints Int               @default(0)
  handledType      ExpiryHandleType
  detailJson       Json?
  createdAt        DateTime           @default(now())

  @@unique([executionDate, handledType])
  @@map("points_expiry_executions")
}

model PointsReminderLog {
  id               Int                @id @default(autoincrement())
  memberId         Int
  member           Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ledgerId         Int
  ledger           PointsLedger       @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  reminderDays     Int
  pointsAmount     Int
  expireAt         DateTime
  notified         Boolean            @default(false)
  createdAt        DateTime           @default(now())

  @@index([memberId, createdAt])
  @@map("points_reminder_logs")
}

enum DashboardComponentType {
  STAT_CARD
  LEVEL_DISTRIBUTION
  CHANNEL_PIE
  BIRTHDAY_REMINDER
  CAMPAIGN_BANNER
  CHECKIN_TREND
  TICKET_SLA
  POINTS_EXPIRY
}

model DashboardComponent {
  id               Int                @id @default(autoincrement())
  type             DashboardComponentType
  title            String
  x                Int                @default(0)
  y                Int                @default(0)
  width            Int                @default(6)
  height           Int                @default(6)
  visible          Boolean          @default(true)
  refreshInterval  Int              @default(0)
  timeRange        String?
  config           Json?
  order            Int              @default(0)
  dashboardConfigId Int
  dashboardConfig  DashboardConfig @relation(fields: [dashboardConfigId], references: [id], onDelete: Cascade)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([dashboardConfigId])
  @@map("dashboard_components")
}

model DashboardConfig {
  id               Int                @id @default(autoincrement())
  userId           Int                @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefaultTemplate Boolean          @default(false)
  components       DashboardComponent[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("dashboard_configs")
}

enum ReferralCodeType {
  PERSONAL
  CAMPAIGN
}

enum ReferralRewardStage {
  REGISTER
  FIRST_ORDER
  CONSUMPTION_TARGET
}

enum ReferralRewardStatus {
  PENDING
  DISTRIBUTED
  CANCELLED
}

enum ReferralAnomalyType {
  SELF_REFERRAL
  CROSS_LEVEL_TAMPER
  CIRCULAR_REFERRAL
  IP_ANOMALY
  DEVICE_ANOMALY
}

model ReferralCode {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  type            ReferralCodeType @default(PERSONAL)
  memberId        Int?
  member          Member?          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  campaignId      Int?
  campaignName    String?
  maxUses         Int              @default(0)
  usedCount       Int              @default(0)
  expiresAt       DateTime?
  isActive        Boolean          @default(true)
  bonusPoints     Int              @default(0)
  refereeBonus    Int              @default(0)
  createdBy       Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([memberId])
  @@index([code])
  @@map("referral_codes")
}

model ReferralReward {
  id              Int                 @id @default(autoincrement())
  referrerId      Int
  referrer        Member              @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId       Int
  referee         Member              @relation("RefereeRewards", fields: [refereeId], references: [id], onDelete: Cascade)
  stage           ReferralRewardStage
  status          ReferralRewardStatus @default(PENDING)
  points          Int                 @default(0)
  targetValue     Float?
  achievedValue   Float?
  distributedAt   DateTime?
  cancelledReason String?
  ruleSnapshot    Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([referrerId, refereeId, stage])
  @@index([referrerId, status])
  @@index([refereeId])
  @@map("referral_rewards")
}

model ReferralRewardRule {
  id              Int                 @id @default(autoincrement())
  name            String
  stage           ReferralRewardStage @unique
  points          Int                 @default(0)
  targetValue     Float?
  isEnabled       Boolean             @default(true)
  levelMultipliers Json?
  description     String?
  createdBy       Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("referral_reward_rules")
}

model ReferralConfig {
  id              Int      @id @default(autoincrement())
  maxDepth        Int      @default(5)
  enableCircularCheck Boolean @default(true)
  enableAnomalyDetection Boolean @default(true)
  bindExpireHours Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@map("referral_configs")
}

model ReferralAnomaly {
  id              Int                 @id @default(autoincrement())
  referrerId      Int
  refereeId       Int
  type            ReferralAnomalyType
  level           Int?
  detail          Json?
  isMarked        Boolean             @default(false)
  markedBy        Int?
  markedAt        DateTime?
  createdAt       DateTime            @default(now())

  @@index([referrerId])
  @@index([refereeId])
  @@index([type, isMarked])
  @@map("referral_anomalies")
}

model ReferralBind {
  id              Int      @id @default(autoincrement())
  referrerId      Int
  refereeId       Int   @unique
  level           Int      @default(1)
  bindChannel     String?
  referralCodeId  Int?
  bindSource      String?
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([referrerId, refereeId])
  @@index([referrerId])
  @@index([refereeId])
  @@map("referral_binds")
}

enum NotificationChannel {
  SMS
  EMAIL
  INAPP
}

enum NotificationTemplateStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  DISABLED
}

enum NotificationTemplateCategory {
  SYSTEM
  BIRTHDAY
  POINTS_EXPIRY
  CAMPAIGN
  TICKET
  OTHER
}

enum NotificationSendStatus {
  PENDING
  SENDING
  SUCCESS
  FAILED
  CANCELLED
}

model NotificationTemplate {
  id               Int                          @id @default(autoincrement())
  name             String
  category         NotificationTemplateCategory @default(OTHER)
  status           NotificationTemplateStatus   @default(DRAFT)
  enabled          Boolean                      @default(true)
  currentVersionId Int?
  channels         Json                         @default("[]")
  variables        Json                         @default("[]")
  createdBy        Int?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  versions         NotificationTemplateVersion[] @relation("TemplateVersions")
  currentVersion   NotificationTemplateVersion?  @relation("CurrentTemplateVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  sendRecords      NotificationSendRecord[]

  @@index([status])
  @@index([category])
  @@map("notification_templates")
}

model NotificationTemplateVersion {
  id              Int                      @id @default(autoincrement())
  templateId      Int
  template        NotificationTemplate     @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  versionNumber   Int
  titleTemplate   String
  contentTemplate String
  channelRules    Json                     @default("{}")
  createdBy       Int?
  remark          String?
  createdAt       DateTime                 @default(now())

  currentOf       NotificationTemplate[]   @relation("CurrentTemplateVersion")
  sendRecords     NotificationSendRecord[]

  @@unique([templateId, versionNumber])
  @@index([templateId])
  @@map("notification_template_versions")
}

model NotificationSendRecord {
  id               Int                      @id @default(autoincrement())
  templateId       Int
  template         NotificationTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersionId Int
  templateVersion  NotificationTemplateVersion @relation(fields: [templateVersionId], references: [id])
  channel          NotificationChannel
  memberIds        Json                     @default("[]")
  variables        Json                     @default("{}")
  status           NotificationSendStatus   @default(PENDING)
  scheduledAt      DateTime?
  sentAt           DateTime?
  totalCount       Int                      @default(0)
  successCount     Int                      @default(0)
  failCount        Int                      @default(0)
  createdBy        Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([templateId])
  @@index([status])
  @@index([channel])
  @@map("notification_send_records")
}

enum BlacklistCategory {
  FRAUD
  MALICIOUS_COMPLAINT
  VIOLATION_EXCHANGE
  ABUSIVE_BEHAVIOR
  OTHER
}

enum BlacklistStatus {
  PENDING_APPROVAL
  ACTIVE
  RELEASED
  REJECTED
}

enum BlacklistActionType {
  POINTS_ADJUST
  SIGNIN
  EXCHANGE
  COUPON
  CAMPAIGN
}

model Blacklist {
  id                Int               @id @default(autoincrement())
  memberId          Int?
  member            Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  phone             String
  memberName        String?
  category          BlacklistCategory
  reason            String
  evidence          String?
  status            BlacklistStatus   @default(PENDING_APPROVAL)
  addedAt           DateTime          @default(now())
  addedBy           Int?
  addedByUser       User?             @relation(fields: [addedBy], references: [id], onDelete: SetNull)
  expectedReleaseAt DateTime?
  releasedAt        DateTime?
  releasedBy        Int?
  releasedByUser    User?             @relation("BlacklistReleasedBy", fields: [releasedBy], references: [id], onDelete: SetNull)
  releaseReason     String?
  restoreOnRelease  Boolean           @default(true)
  approvedAt        DateTime?
  approvedBy        Int?
  approvedByUser    User?             @relation("BlacklistApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejectReason      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  auditLogs         BlacklistAuditLog[]

  @@index([memberId])
  @@index([phone])
  @@index([status])
  @@index([category])
  @@index([expectedReleaseAt])
  @@map("blacklists")
}

model BlacklistAuditLog {
  id            Int                @id @default(autoincrement())
  blacklistId   Int?
  blacklist     Blacklist?         @relation(fields: [blacklistId], references: [id], onDelete: SetNull)
  memberId      Int?
  member        Member?            @relation(fields: [memberId], references: [id], onDelete: SetNull)
  phone         String
  actionType    BlacklistActionType
  actionDetail  String?
  blocked       Boolean            @default(true)
  operatorId    Int?
  operator      User?              @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())

  @@index([memberId])
  @@index([phone])
  @@index([actionType])
  @@index([createdAt])
  @@map("blacklist_audit_logs")
}

model BlacklistConfig {
  id                   Int      @id @default(autoincrement())
  autoReleaseEnabled   Boolean  @default(true)
  restoreOnAutoRelease Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())

  @@map("blacklist_configs")
}

enum ScheduledTaskStatus {
  RUNNING
  PAUSED
  ERROR
  EXECUTING
}

enum ScheduledTaskModule {
  POINTS
  BLACKLIST
  CAMPAIGN
  MEMBER
  TICKET
  REFERRAL
  SYSTEM
}

model ScheduledTask {
  id                   Int                 @id @default(autoincrement())
  name                 String              @unique
  displayName          String
  cronExpression       String
  description          String?
  module               ScheduledTaskModule @default(SYSTEM)
  status               ScheduledTaskStatus @default(RUNNING)
  lastExecutionAt      DateTime?
  nextExecutionAt      DateTime?
  lastDurationMs       Int?                @default(0)
  timeoutSeconds       Int                 @default(300)
  maxRetryCount        Int                 @default(3)
  retryIntervalSeconds Int                 @default(60)
  consecutiveFailures  Int                 @default(0)
  failureThreshold     Int                 @default(5)
  handler              String
  isEnabled            Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  executionLogs        TaskExecutionLog[]
  dependenciesAsChild  TaskDependency[]    @relation("TaskChildDependencies")
  dependenciesAsParent TaskDependency[]    @relation("TaskParentDependencies")

  @@index([status])
  @@index([module])
  @@map("scheduled_tasks")
}

enum TaskExecutionStatus {
  SUCCESS
  FAILED
  TIMEOUT
  SKIPPED
}

model TaskExecutionLog {
  id             Int                 @id @default(autoincrement())
  taskId         Int
  task           ScheduledTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  durationMs     Int                 @default(0)
  status         TaskExecutionStatus
  processedCount Int                 @default(0)
  outputSummary  String?
  errorStack     String?
  triggeredBy    String?             @default("SYSTEM")
  retryCount     Int                 @default(0)
  createdAt      DateTime            @default(now())

  @@index([taskId, createdAt])
  @@index([status, createdAt])
  @@map("task_execution_logs")
}

model TaskDependency {
  id         Int           @id @default(autoincrement())
  parentTaskId Int
  parentTask ScheduledTask @relation("TaskParentDependencies", fields: [parentTaskId], references: [id], onDelete: Cascade)
  childTaskId  Int
  childTask  ScheduledTask @relation("TaskChildDependencies", fields: [childTaskId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@unique([parentTaskId, childTaskId])
  @@index([parentTaskId])
  @@index([childTaskId])
  @@map("task_dependencies")
}

enum SystemNotificationLevel {
  INFO
  WARNING
  URGENT
}

enum SystemNotificationStatus {
  UNREAD
  READ
  DISMISSED
}

model SystemNotification {
  id        Int                     @id @default(autoincrement())
  title     String
  content   String
  level     SystemNotificationLevel @default(INFO)
  status    SystemNotificationStatus @default(UNREAD)
  category  String?
  relatedId Int?
  userId    Int?
  createdAt DateTime                @default(now())
  readAt    DateTime?

  @@index([status])
  @@index([level])
  @@index([userId])
  @@map("system_notifications")
}
